# NVIDIA Nemotron LLM API Configuration
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Backend Configuration (Optional)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=True

# CORS Configuration
# For production, replace "*" with specific domain: https://yourdomain.com
CORS_ORIGINS=*
